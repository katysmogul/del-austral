# Esta carpeta guarda los comprobantes de pago (PDF, JPG, PNG)
# subidos por el Apoderado. Por seguridad, se impide que
# cualquier archivo se ejecute como script, incluso si alguien
# lograra subir un archivo con extensión engañosa.

<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|cgi|sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Evita que se liste el contenido de la carpeta desde el navegador.
Options -Indexes
